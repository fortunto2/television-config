#!/usr/bin/env python3
"""Preview a Claude Code history entry by timestamp.
Usage: tv-claude-history-preview <ts_ms>
Shows full prompt + nearby entries from same project.
"""
import json
import signal
import sys
import textwrap
from datetime import datetime, timezone
from pathlib import Path

signal.signal(signal.SIGPIPE, signal.SIG_DFL)

if len(sys.argv) < 2:
    sys.exit(0)

try:
    target_ts = int(sys.argv[1])
except ValueError:
    print(sys.argv[1])
    sys.exit(0)

history_file = Path.home() / ".claude" / "history.jsonl"
if not history_file.exists():
    sys.exit(0)

home = str(Path.home())
entries = []

with open(history_file) as f:
    for line in f:
        try:
            entries.append(json.loads(line))
        except json.JSONDecodeError:
            continue

# Find by timestamp (exact match)
match = None
match_idx = -1
for i, d in enumerate(entries):
    if d.get("timestamp") == target_ts:
        match = d
        match_idx = i
        break

if not match:
    print("Entry not found")
    sys.exit(0)

project = match.get("project", "").replace(home + "/", "") or "~"
ts = datetime.fromtimestamp(target_ts / 1000, tz=timezone.utc).strftime("%Y-%m-%d %H:%M UTC")

print(f"\033[1;33mProject:\033[0m {project}")
print(f"\033[1;33mDate:\033[0m    {ts}")
print(f"\033[1;32m{'─' * 60}\033[0m")
print()

full_text = match.get("display", "")
for line in full_text.split("\n"):
    if line.strip():
        print(textwrap.fill(line, width=78))
    else:
        print()

# Context: nearby entries from same project
proj_full = match.get("project", "")
before = []
after = []
for j in range(max(0, match_idx - 5), match_idx):
    if entries[j].get("project") == proj_full:
        before.append(entries[j])
for j in range(match_idx + 1, min(len(entries), match_idx + 5)):
    if entries[j].get("project") == proj_full:
        after.append(entries[j])

if before or after:
    print()
    print(f"\033[1;32m{'─' * 60}\033[0m")

if before:
    print(f"\033[1;36mBefore:\033[0m")
    for e in before:
        t = datetime.fromtimestamp(e["timestamp"] / 1000, tz=timezone.utc).strftime("%H:%M")
        msg = e.get("display", "")[:100].replace("\n", " ")
        print(f"  \033[2m{t}\033[0m {msg}")

if after:
    print(f"\033[1;36mAfter:\033[0m")
    for e in after:
        t = datetime.fromtimestamp(e["timestamp"] / 1000, tz=timezone.utc).strftime("%H:%M")
        msg = e.get("display", "")[:100].replace("\n", " ")
        print(f"  \033[2m{t}\033[0m {msg}")
