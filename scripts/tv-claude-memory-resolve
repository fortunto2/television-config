#!/usr/bin/env bash
# Resolve shortened tv-claude-memory path back to absolute path.
# Usage: tv-claude-memory-resolve "startups-active-FaceAlarm/mem/MEMORY.md"
input="$1"
HOME_DIR="$HOME"

# .global/CLAUDE.md → ~/.claude/CLAUDE.md
if [[ "$input" == ".global/CLAUDE.md" ]]; then
    echo "$HOME_DIR/.claude/CLAUDE.md"; exit 0
fi

# .rules/foo.md → ~/.claude/rules/foo.md
if [[ "$input" == .rules/* ]]; then
    echo "$HOME_DIR/.claude/rules/${input#.rules/}"; exit 0
fi

# startups/foo/... → ~/startups/foo/...
if [[ "$input" == startups/* ]]; then
    echo "$HOME_DIR/$input"; exit 0
fi

# projects/foo/... → ~/projects/foo/...
if [[ "$input" == projects/* ]]; then
    echo "$HOME_DIR/$input"; exit 0
fi

# anything-with/mem/file.md → ~/.claude/projects/-Users-rustam-{path}/memory/file.md
if [[ "$input" == *"/mem/"* ]]; then
    project_part="${input%%/mem/*}"
    file_part="${input#*/mem/}"
    echo "$HOME_DIR/.claude/projects/-Users-rustam-$project_part/memory/$file_part"; exit 0
fi

# Fallback: try as-is under home
echo "$HOME_DIR/$input"
